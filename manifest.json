{
  "manifest_version": 3,
  "name": "Codeforces 2 PC^2",
  "version": "1.0",
  "description": "Replaces Codeforces contest pages with a PC^2-style interface.",
  "content_scripts": [
    {
      "matches": [
        "https://codeforces.com/*",
        "https://*.codeforces.com/*"
      ],
      "js": [
        "src/state.js",
        "src/ui.js",
        "src/api.js",
        "src/main.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["pc2-styles.css"],
      "matches": ["https://codeforces.com/*", "https://*.codeforces.com/*"]
    }
  ]
}